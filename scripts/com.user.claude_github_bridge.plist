<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- ジョブ識別子 -->
  <key>Label</key>
  <string>com.user.claude_github_bridge</string>

  <!-- 実行コマンド: 毎週月曜 09:00 に PR レビューを実行する例 -->
  <!-- 用途に合わせて ProgramArguments を変更すること -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/masahiro/projects/claude_github_bridge/scripts/run_github_task.sh</string>
    <string>review-pr</string>
    <string>--repo</string>
    <string>owner/repo</string>   <!-- ← 実際のリポジトリに変更 -->
    <string>--pr</string>
    <string>latest</string>       <!-- ← 実際のPR番号またはスクリプト変数に変更 -->
    <string>--post</string>
  </array>

  <!-- 毎週月曜 09:00 に実行 -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key> <integer>1</integer>
    <key>Hour</key>    <integer>9</integer>
    <key>Minute</key>  <integer>0</integer>
  </dict>

  <!-- スリープ復帰後に未実行なら即実行 -->
  <key>RunAtLoad</key>
  <false/>

  <!-- 標準出力・エラーをログファイルへ -->
  <key>StandardOutPath</key>
  <string>/Users/masahiro/projects/claude_github_bridge/scripts/logs/launchd_stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/masahiro/projects/claude_github_bridge/scripts/logs/launchd_stderr.log</string>

  <!-- PATH を明示（claude バイナリのパスが通るように） -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/masahiro/.local/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/masahiro</string>
  </dict>
</dict>
</plist>
